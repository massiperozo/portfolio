    color: #C4B5FD;
  }

  .panel-card-purple {
    background: linear-gradient(160deg, rgba(139, 92, 246, 0.5), rgba(196, 181, 253, 0.35));
  }
</style>

<script>
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function updateVenezuelaTime() {
    const el = document.getElementById('local-time-value');
    if (!el) return;
    const now = new Date();
    const options: Intl.DateTimeFormatOptions = {
      hour: '2-digit',
      minute: '2-digit',
      hour12: false,
      timeZone: 'America/Caracas',
    };
    el.textContent = new Intl.DateTimeFormat('es-VE', options).format(now);
  }
  updateVenezuelaTime();
  setInterval(updateVenezuelaTime, 60000);

  if (!reducedMotion) {
    const parallaxElements = document.querySelectorAll<HTMLElement>('[data-parallax]');
    const reveals = document.querySelectorAll<HTMLElement>('[data-reveal]');
    const navLinks = document.querySelectorAll<HTMLElement>('[data-nav-link]');
    const sections = document.querySelectorAll<HTMLElement>('[data-section]');
    const progressBar = document.getElementById('scroll-progress') as HTMLElement | null;

    let ticking = false;
    const updateParallax = () => {
      const scrollY = window.scrollY;
      const maxScroll = Math.max(document.body.scrollHeight - window.innerHeight, 1);

      parallaxElements.forEach((element) => {
        const speed = Number(element.getAttribute('data-parallax')) || 0;
        element.style.transform = `translate3d(0, ${scrollY * speed}px, 0)`;
      });

      if (progressBar) {
        const progress = Math.min(100, Math.max(8, (scrollY / maxScroll) * 100));
        progressBar.style.height = `${progress}%`;
      }

      ticking = false;
    };

    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(updateParallax);
        ticking = true;
      }
    });

    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -10% 0px' }
    );

    reveals.forEach((section) => revealObserver.observe(section));

    const activeObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          const sectionId = entry.target.id;
          navLinks.forEach((link) => {
            const isActive = link.getAttribute('href') === `#${sectionId}`;
            link.classList.toggle('text-[#8B5CF6]', isActive);
            link.classList.toggle('text-white/65', !isActive);
          });
        });
      },
      { threshold: 0.5 }
    );

    sections.forEach((section) => {
      if (section.id) activeObserver.observe(section);
    });

    updateParallax();
  } else {
    document.querySelectorAll<HTMLElement>('[data-reveal]').forEach((section) => section.classList.add('is-visible'));
  }
</script>
