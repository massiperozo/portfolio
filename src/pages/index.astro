---
import Layout from '../layouts/Layout.astro';
import massielProfile from '../assets/Massiel_Perozo - portafolio.png';
import ibmLogo from '../assets/ibm.svg';
import fortinetLogo from '../assets/Fortinet_logo.svg';

const navItems = [
	{ label: 'Inicio', href: '#inicio' },
	{ label: 'Proyectos', href: '#proyectos' },
	{ label: 'Sobre Mí', href: '#sobre-mi' },
	{ label: 'Contacto', href: '#contacto' },
];

const skills = [
	{
		title: 'Python',
		description: 'Automatización, backend y scripting orientado a seguridad.',
	},
	{
		title: 'JS / TS',
		description: 'Interfaces robustas y experiencias web enfocadas en rendimiento.',
	},
	{
		title: 'Node.js',
		description: 'APIs escalables y arquitectura de servicios en tiempo real.',
	},
	{
		title: 'Ciberseguridad',
		description: 'Hardening, análisis de riesgo y defensa aplicada al producto.',
	},
];

const projects = [
	{
		title: 'Framework de Ciberseguridad Aplicada',
		href: 'https://github.com/massiperozo/ciberseguridad-proyecto.git',
	},
	{
		title: 'Intelligent Telegram Bot',
		href: 'https://github.com/massiperozo/TelegramBotRedes.git',
	},
];

const socialLinks = [
	{ label: 'LinkedIn', href: '#' },
	{ label: 'GitHub', href: '#' },
	{ label: 'X', href: '#' },
];
---

<Layout>
	<div class="portfolio-shell relative min-h-screen overflow-x-clip bg-[#0F0F12] text-white">
		<div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
			<div class="ambient-grid absolute inset-0 opacity-45"></div>
			<div class="ambient-noise absolute inset-0 opacity-20"></div>
			<div data-parallax="0.06" class="parallax-orb absolute -left-16 top-8 h-64 w-64 rounded-full bg-[#8B5CF6]/20 blur-3xl"></div>
			<div data-parallax="0.1" class="parallax-orb absolute -right-20 top-64 h-80 w-80 rounded-full bg-[#8B5CF6]/15 blur-3xl"></div>
			<div data-parallax="0.14" class="parallax-orb absolute bottom-[-7rem] left-1/2 h-96 w-96 -translate-x-1/2 rounded-full bg-[#8B5CF6]/10 blur-[140px]"></div>
			<div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_10%,rgba(139,92,246,0.18),transparent_42%)]"></div>
			<span class="ambient-glyph left-[10%] top-[18%] hidden md:block">&#123; &#125;</span>
			<span class="ambient-glyph right-[12%] top-[22%] hidden md:block">&lt;/&gt;</span>
			<span class="ambient-glyph left-[20%] top-[58%] hidden md:block">//</span>
			<span class="ambient-glyph right-[14%] top-[68%] hidden md:block">#</span>
		</div>

		<header class="sticky top-0 z-40 border-b border-white/10 bg-[#0F0F12]/75 backdrop-blur-xl">
			<div class="mx-auto flex w-full max-w-6xl items-center justify-between px-5 py-4 md:px-8">
				<a href="#inicio" class="text-sm font-semibold tracking-[0.24em] text-white/90">PM</a>
				<nav aria-label="Principal" class="hidden md:block">
					<ul class="flex items-center gap-8 text-sm text-white/70">
						{
							navItems.map((item) => (
								<li>
									<a
										href={item.href}
										data-nav-link
										class="transition hover:text-[#8B5CF6] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#8B5CF6] focus-visible:ring-offset-2 focus-visible:ring-offset-[#0F0F12]"
									>
										{item.label}
									</a>
								</li>
							))
						}
					</ul>
				</nav>
				<a
					href="#contacto"
					class="rounded-full border border-[#8B5CF6]/40 bg-[#8B5CF6]/10 px-4 py-2 text-xs font-semibold tracking-wide text-[#C6B4FF] transition hover:border-[#8B5CF6] hover:bg-[#8B5CF6]/15 md:hidden"
				>
					Contacto
				</a>
			</div>
		</header>

		<main class="mx-auto flex w-full max-w-6xl flex-col gap-20 px-5 pb-14 pt-10 md:gap-28 md:px-8 md:pt-14">
			<section id="inicio" data-section data-reveal class="reveal-up grid gap-10 lg:grid-cols-[1.45fr_0.9fr] lg:items-start">
				<div class="space-y-8">
					<p class="inline-flex w-fit rounded-full border border-white/15 bg-white/[0.03] px-3 py-1 text-xs font-medium uppercase tracking-[0.2em] text-white/70">
						Portafolio profesional
					</p>
					<h1 class="max-w-4xl text-balance text-4xl font-bold leading-[1.05] tracking-tight text-white sm:text-5xl md:text-6xl lg:text-7xl">
						Ingeniera Informática enfocada en Desarrollo Fullstack y Ciberseguridad.
						<span class="text-[#8B5CF6]">
							Transformo desafíos complejos en productos digitales seguros y escalables.
						</span>
					</h1>
					<div class="flex flex-col gap-3 sm:flex-row sm:items-center">
						<a
							href="#contacto"
							class="inline-flex w-fit items-center justify-center rounded-full bg-gradient-to-r from-[#8B5CF6] via-[#A78BFA] to-[#8B5CF6] px-6 py-3 text-sm font-semibold text-white shadow-[0_0_30px_rgba(139,92,246,0.35)] transition hover:-translate-y-0.5"
						>
							Hablemos
						</a>
						<span class="text-sm text-white/65">Diseño y desarrollo de soluciones seguras, de punta a punta.</span>
					</div>
				</div>

				<aside class="rounded-3xl border border-white/10 bg-white/[0.03] p-5">
					<div class="rounded-2xl border border-dashed border-[#8B5CF6]/35 bg-[#111118] p-5 text-center">
						<div class="mt-4 overflow-hidden rounded-xl border border-white/10 bg-[#0B0B0E]">
							<img
								src={massielProfile.src}
								alt="Retrato de Massiel Perozo"
								class="h-64 w-full object-cover sm:h-72"
								loading="lazy"
							/>
						</div>
					</div>
					<div class="mt-4 space-y-3">
						<p class="text-xs uppercase tracking-[0.24em] text-white/50">Certificaciones</p>
						<div class="grid grid-cols-2 gap-3">
							<div class="grid place-items-center rounded-xl border border-white/10 bg-[#111118] p-3">
								<img
									src={ibmLogo.src}
									alt="Logo de certificación IBM"
									class="h-10 w-auto object-contain"
									loading="lazy"
								/>
							</div>
							<div class="grid place-items-center rounded-xl border border-white/10 bg-[#111118] p-3">
								<img
									src={fortinetLogo.src}
									alt="Logo de certificación Fortinet"
									class="h-10 w-auto object-contain"
									loading="lazy"
								/>
							</div>
						</div>
					</div>
				</aside>
			</section>

			<section data-section data-reveal aria-labelledby="skills-title" class="reveal-up space-y-6">
				<h2 id="skills-title" class="text-sm font-semibold uppercase tracking-[0.22em] text-[#C6B4FF]">
					Skills Stack
				</h2>
				<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
					{
						skills.map((skill) => (
							<article class="group rounded-2xl border border-white/10 bg-white/[0.02] p-5 transition hover:-translate-y-1 hover:border-[#8B5CF6]/70 hover:bg-[#8B5CF6]/10">
								<h3 class="text-xl font-semibold text-white transition group-hover:text-[#C6B4FF]">{skill.title}</h3>
								<p class="mt-3 text-sm leading-relaxed text-white/65">{skill.description}</p>
							</article>
						))
					}
				</div>
			</section>

			<section id="proyectos" data-section data-reveal aria-labelledby="projects-title" class="reveal-up space-y-6">
				<h2 id="projects-title" class="text-sm font-semibold uppercase tracking-[0.22em] text-[#C6B4FF]">
					Proyectos
				</h2>
				<ul class="divide-y divide-white/10 rounded-2xl border border-white/10 bg-white/[0.02]">
					{
						projects.map((project) => (
							<li>
								<a
									href={project.href}
									target={project.href.startsWith('http') ? '_blank' : undefined}
									rel={project.href.startsWith('http') ? 'noopener noreferrer' : undefined}
									class="flex items-center justify-between px-5 py-5 text-base font-medium text-white/85 transition hover:bg-[#8B5CF6]/10 hover:text-[#8B5CF6] sm:text-lg"
								>
									<span>{project.title}</span>
									<span class="text-white/35">→</span>
								</a>
							</li>
						))
					}
				</ul>
			</section>

			<section id="sobre-mi" data-section data-reveal class="reveal-up grid gap-6 rounded-3xl border border-white/10 bg-white/[0.02] p-6 md:grid-cols-2 md:items-center md:p-8">
				<div>
					<p class="text-sm font-semibold uppercase tracking-[0.22em] text-[#C6B4FF]">Sobre Mí</p>
					<h2 class="mt-3 text-2xl font-bold leading-tight text-white sm:text-3xl">
						Mentora de Código en Technovation Girls y profesional formada en la UCAB.
					</h2>
				</div>
				<p class="text-sm leading-relaxed text-white/70 sm:text-base">
					Acompaño a nuevas generaciones a construir tecnología con propósito y seguridad desde el diseño.
					Combino ingeniería de software, visión de producto y ciberseguridad para entregar soluciones sostenibles.
				</p>
			</section>
		</main>

		<footer id="contacto" data-section data-reveal class="reveal-up border-t border-white/10 bg-[#0B0B0E]/80">
			<div class="mx-auto flex w-full max-w-6xl flex-col gap-5 px-5 py-8 md:flex-row md:items-center md:justify-between md:px-8">
				<div class="space-y-2">
					<p class="text-xs uppercase tracking-[0.22em] text-white/45">Contacto</p>
					<a href="mailto:massiperozob@gmail.com" class="text-base font-semibold text-white transition hover:text-[#8B5CF6]">
						massiperozob@gmail.com
					</a>
				</div>
				<div class="flex items-center gap-3">
					{
						socialLinks.map((social) => (
							<a
								href={social.href}
								class="rounded-full border border-white/15 px-4 py-2 text-sm text-white/70 transition hover:border-[#8B5CF6] hover:bg-[#8B5CF6]/10 hover:text-[#C6B4FF]"
							>
								{social.label}
							</a>
						))
					}
				</div>
			</div>
		</footer>
	</div>
</Layout>

<script>
	const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	if (!reducedMotion) {
		const parallaxElements = document.querySelectorAll<HTMLElement>('[data-parallax]');
		const reveals = document.querySelectorAll<HTMLElement>('[data-reveal]');
		const navLinks = document.querySelectorAll<HTMLElement>('[data-nav-link]');
		const sections = document.querySelectorAll<HTMLElement>('[data-section]');

		let ticking = false;
		const updateParallax = () => {
			const scrollY = window.scrollY;
			parallaxElements.forEach((element) => {
				const speed = Number(element.getAttribute('data-parallax')) || 0;
				element.style.transform = `translate3d(0, ${scrollY * speed}px, 0)`;
			});
			ticking = false;
		};

		window.addEventListener('scroll', () => {
			if (!ticking) {
				window.requestAnimationFrame(updateParallax);
				ticking = true;
			}
		});

		const revealObserver = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add('is-visible');
					}
				});
			},
			{ threshold: 0.18, rootMargin: '0px 0px -12% 0px' }
		);

		reveals.forEach((section) => revealObserver.observe(section));

		const activeObserver = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (!entry.isIntersecting) return;

					const sectionId = entry.target.id;
					navLinks.forEach((link) => {
						const isActive = link.getAttribute('href') === `#${sectionId}`;
						link.classList.toggle('text-[#8B5CF6]', isActive);
						link.classList.toggle('font-semibold', isActive);
						link.classList.toggle('text-white/70', !isActive);
					});
				});
			},
			{ threshold: 0.45 }
		);

		sections.forEach((section) => {
			if (section.id) activeObserver.observe(section);
		});

		updateParallax();
	} else {
		document.querySelectorAll('[data-reveal]').forEach((section) => section.classList.add('is-visible'));
	}
</script>
