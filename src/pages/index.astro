---
import Layout from '../layouts/Layout.astro';
import massielProfile from '../assets/Massiel_Perozo - portafolio.png';
import ibmLogo from '../assets/ibm.svg';
import fortinetLogo from '../assets/Fortinet_logo.svg';
import ucaLogo from '../assets/imagen ucab - portafolio.png';
import technovationLogo from '../assets/TechnovationGirls-portafolio.png';

const topNav = [
  { label: 'Inicio', href: '#inicio' },
  { label: 'Sobre Mi', href: '#sobre-mi' },
  { label: 'Experiencia', href: '#experiencia' },
  
  { label: 'Proyectos', href: '#proyectos' },
  { label: 'Skills', href: '#skills' },
  { label: 'Contacto', href: '#contacto' },
];

const sideNav = [
  { label: 'Inicio', href: '#inicio', icon: 'home' },
  { label: 'Sobre Mi', href: '#sobre-mi', icon: 'user' },
  { label: 'Experiencia', href: '#experiencia', icon: 'experience' },
  { label: 'Proyectos', href: '#proyectos', icon: 'briefcase' },
  { label: 'Skills', href: '#skills', icon: 'flask' },
  { label: 'Contacto', href: '#contacto', icon: 'mail' },
];

const experiences = [
  {
    role: 'Pasante de desarrollo',
    company: 'Laboratorio de Innovación Digital',
    period: 'feb. 2026 - actualidad · 3 meses',
    description:
      'Desarrollo de una herramienta de medición cultural para las empresas. Dicha herramienta permite apoyar a distintas empresas con su evolución y mejora con el apoyo de nuevas herramientas e Inteligencia Artificial.',
    tags: [],
  },
  {
    role: 'Pasante de desarrollo',
    company: 'Uptek Solutions · Contrato de formación',
    period: 'feb. 2026 - abr. 2026 · 3 meses',
    description:
      'Desarrollo de un Sistema Centralizado de Notificaciones, para el envío de notificaciones a distintas plataformas con distintas plantillas.',
    tags: ['Kubernetes', 'Gestión de eventos', '1 aptitud más'],
  },
  {
    role: 'Mentora de código',
    company: 'Technovation Girls Venezuela',
    period: '2025',
    description:
      'Mentoría de código para diversos grupos de niñas, con la oportunidad de conectar con niñas jóvenes e inspirarlas a entrar al mundo de la tecnología.',
    tags: ['Mentorship', 'Education', 'Community'],
  },
];

const projects = [
  {
    title: 'Framework de Ciberseguridad',
    description: 'Desarrollo de herramientas de analisis de vulnerabilidades y buenas practicas de seguridad informatica.',
    tags: ['Python', 'IBM', 'Fortinet', 'Security'],
    year: '2024',
    href: 'https://github.com/massiperozo/ciberseguridad-proyecto.git',
  },
  {
    title: 'Telegram Bot Intelligence',
    description: 'Bot de automatizacion para gestion de redes sociales y atencion al cliente.',
    tags: ['Node.js', 'JavaScript', 'Telegram API', 'Automation'],
    year: '2024',
    href: 'https://github.com/massiperozo/TelegramBotRedes.git',
  },
];

const skillCards = [
  {
    title: 'Fullstack Development',
    subtitle: 'JavaScript & TypeScript',
    description: 'Desarrollo de aplicaciones web completas con Node.js, Next.js, Express y React.',
    tags: ['TypeScript', 'JavaScript', 'Node.js', 'Next.js', 'React', 'Python'],
    emphasis: true,
  },
  {
    title: 'Ciberseguridad',
    subtitle: 'IBM & Fortinet Certified',
    description: 'Analisis de vulnerabilidades, implementacion de protocolos de seguridad y desarrollo seguro.',
    tags: ['Security', 'OWASP', 'ISO 27001'],
  },
  {
    title: 'Estrategia Digital',
    subtitle: 'Product & Growth',
    description: 'Definicion de producto y mejora continua con enfoque en valor real.',
    tags: ['Product Strategy', 'UX/UI', 'Growth'],
  },
  {
    title: 'Bases de Datos',
    subtitle: 'SQL & NoSQL',
    description: 'Modelado y optimizacion de consultas para aplicaciones en produccion.',
    tags: ['PostgreSQL', 'MongoDB', 'MySQL'],
  },
  {
    title: 'DevOps & Tools',
    subtitle: 'CI/CD & Cloud',
    description: 'Automatizacion de flujo de trabajo, calidad y despliegues continuos.',
    tags: ['Git', 'Docker', 'Linux'],
  },
  {
    title: 'Idiomas',
    subtitle: 'Comunicacion Global',
    description: 'Colaboracion efectiva en entornos tecnicos multiculturales.',
    tags: ['Espanol Nativo', 'Ingles B2'],
  },
];

const contacts = [
  { label: 'EMAIL', value: 'massiperozob@gmail.com', href: 'https://mail.google.com/mail/?view=cm&fs=1&to=massiperozob@gmail.com' },
  { label: 'LINKEDIN', value: '@massielperozo', href: 'https://www.linkedin.com/in/massiel-perozo-5b30b4304/' },
  { label: 'GITHUB', value: '@massiperozo', href: 'https://github.com/massiperozo' },
];
---

<Layout>
  <div class="relative min-h-screen bg-transparent text-white">
    <div class="pointer-events-none fixed inset-0 z-0 overflow-hidden">
      <div class="hero-mesh absolute inset-0"></div>
      <div class="ambient-grid absolute inset-0 opacity-32"></div>
      <div class="ambient-noise absolute inset-0 opacity-18"></div>
      <div data-parallax="0.03" class="parallax-orb absolute -left-24 top-[-5rem] h-[24rem] w-[24rem] rounded-full bg-[#8B5CF6]/18 blur-[130px]"></div>
      <div data-parallax="0.07" class="parallax-orb absolute right-[-10rem] top-[16%] h-[32rem] w-[32rem] rounded-full bg-[#C4B5FD]/12 blur-[160px]"></div>
      <div data-parallax="0.11" class="parallax-orb absolute left-[18%] top-[52%] h-[34rem] w-[34rem] rounded-full bg-[#8B5CF6]/10 blur-[180px]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_42%,rgba(139,92,246,0.2),transparent_38%),radial-gradient(circle_at_22%_22%,rgba(196,181,253,0.08),transparent_24%),radial-gradient(circle_at_78%_72%,rgba(16,185,129,0.08),transparent_22%)]"></div>
      <div class="tech-line tech-line-left"></div>
      <div class="tech-line tech-line-right"></div>
      <span data-parallax="0.05" class="ambient-glyph ambient-glyph-code left-[14%] top-[18%] hidden md:block">&lt;/&gt;</span>
      <span data-parallax="0.08" class="ambient-glyph ambient-glyph-code right-[16%] top-[16%] hidden md:block">{ }</span>
      <span data-parallax="0.12" class="ambient-glyph ambient-glyph-code left-[18%] top-[54%] hidden md:block">&lt;code&gt;</span>
      <span data-parallax="0.09" class="ambient-glyph ambient-glyph-code right-[19%] top-[58%] hidden md:block">#</span>
      <span data-parallax="0.13" class="ambient-glyph ambient-glyph-code right-[34%] top-[67%] hidden md:block">console.log()</span>
      <span data-parallax="0.1" class="ambient-glyph ambient-glyph-code left-[55%] top-[15%] hidden md:block">npm</span>
      <span data-parallax="0.16" class="ambient-glyph ambient-glyph-code right-[69%] top-[40%] hidden md:block">git</span>
      <span data-parallax="0.19" class="ambient-glyph ambient-glyph-code left-[72%] top-[32%] hidden md:block">async</span>
    </div>

    <aside class="fixed left-0 top-0 z-50 hidden h-screen w-[4.5rem] border-r border-white/10 bg-[#19191D]/90 md:flex md:flex-col md:items-center">
      <a href="#inicio" class="mt-6 text-4xl font-bold tracking-tight text-[#8B5CF6]">M</a>
      <div class="mt-8 flex flex-col items-center gap-4">
        {
          sideNav.map((item) => (
            <a
              href={item.href}
              data-nav-link
              class="group grid h-9 w-9 place-items-center rounded-lg border border-transparent text-white/50 transition hover:border-white/15 hover:bg-white/[0.04] hover:text-[#8B5CF6]"
              aria-label={item.label}
            >
              {item.icon === 'home' && (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                  <path d="M3 11.5L12 4l9 7.5" />
                  <path d="M5 10.5V20h14v-9.5" />
                </svg>
              )}
              {item.icon === 'user' && (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                  <circle cx="12" cy="8" r="3.5" />
                  <path d="M4.5 20c1.8-3.3 4.3-5 7.5-5s5.7 1.7 7.5 5" />
                </svg>
              )}
              {item.icon === 'briefcase' && (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                  <rect x="3" y="7" width="18" height="13" rx="2" />
                  <path d="M9 7V5a1 1 0 011-1h4a1 1 0 011 1v2" />
                </svg>
              )}
              {item.icon === 'experience' && (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                  <path d="M12 3v18" />
                  <path d="M7 7h10" />
                  <path d="M7 17h10" />
                  <path d="M8.5 7c0 2.2 1.5 4 3.5 4s3.5-1.8 3.5-4" />
                  <path d="M8.5 17c0-2.2 1.5-4 3.5-4s3.5 1.8 3.5 4" />
                </svg>
              )}
              {item.icon === 'flask' && (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                  <path d="M10 3h4" />
                  <path d="M10 3v5l-5 9a2 2 0 001.7 3h10.6a2 2 0 001.7-3l-5-9V3" />
                </svg>
              )}
              {item.icon === 'mail' && (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                  <rect x="3" y="5" width="18" height="14" rx="2" />
                  <path d="M3 7l9 6 9-6" />
                </svg>
              )}
            </a>
          ))
        }
      </div>
      <div class="mb-5 mt-auto h-24 w-[2px] rounded-full bg-white/10">
        <div id="scroll-progress" class="w-full rounded-full bg-[#8B5CF6]" style="height: 8%;"></div>
      </div>
    </aside>

    <header class="sticky top-0 z-40 border-b border-white/10 bg-[#0F0F12]/70 backdrop-blur-xl md:ml-[4.5rem]">
      <div class="mx-auto flex w-full max-w-6xl items-center justify-between px-4 py-4 md:px-7">
        <a href="#inicio" class="text-xl font-bold tracking-tight text-[#8B5CF6] md:hidden">M</a>
        <nav aria-label="Principal" class="hidden md:block">
          <ul class="flex items-center gap-7 text-xs uppercase tracking-[0.22em] text-white/65">
            {
              topNav.map((item) => (
                <li>
                  <a
                    href={item.href}
                    data-nav-link
                    class="transition hover:text-[#8B5CF6] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#8B5CF6] focus-visible:ring-offset-2 focus-visible:ring-offset-[#0F0F12]"
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
        <a href="#contacto" class="rounded-full border border-[#8B5CF6]/40 bg-[#8B5CF6]/10 px-4 py-2 text-xs font-semibold tracking-wide text-[#C4B5FD] transition hover:border-[#8B5CF6] hover:bg-[#8B5CF6]/15 md:hidden">Contacto</a>
      </div>
    </header>

    <main class="relative z-10 md:ml-[4.5rem]">
      <section id="inicio" data-section data-reveal class="reveal-up mx-auto flex min-h-screen w-full max-w-6xl flex-col items-center justify-center px-5 py-20 text-center md:px-8">
        <h1 class="mt-6 max-w-4xl text-balance text-5xl font-bold leading-[1.07] tracking-tight text-white sm:text-6xl lg:text-7xl">
          Hola, soy Massiel, una
          <span class="bg-gradient-to-r from-[#8B5CF6] to-[#C4B5FD] bg-clip-text text-transparent">desarrolladora autodidacta y creativa</span>
        </h1>
        <p class="mt-7 max-w-3xl text-lg leading-relaxed text-[#A1A1AA]">
          Transformo desafios complejos en productos digitales seguros, eficientes y centrados en el usuario,
          fusionando visión técnica con creatividad y estética.
        </p>
        <div class="mt-11 flex flex-wrap items-center justify-center gap-7 text-xs text-[#A1A1AA]">
          <span id="local-time">Venezuela - Hora local <span id="local-time-value">--:--</span></span>
          <a href="https://www.linkedin.com/in/massiel-perozo-5b30b4304/" target="_blank" rel="noopener noreferrer" class="hover:text-[#8B5CF6]">LinkedIn</a>
          <a href="https://github.com/massiperozo" target="_blank" rel="noopener noreferrer" class="hover:text-[#8B5CF6]">GitHub</a>
          <a href="https://mail.google.com/mail/?view=cm&fs=1&to=massiperozob@gmail.com" class="hover:text-[#8B5CF6]">Email</a>
        </div>
        <a href="#contacto" class="mt-12 inline-flex items-center gap-2 rounded-full border border-[#8B5CF6]/35 bg-[#8B5CF6]/15 px-5 py-2 text-sm font-semibold text-[#C4B5FD] transition hover:translate-y-[-1px] hover:bg-[#8B5CF6]/25">trabajemos juntos<span aria-hidden="true">-&gt;</span></a>
      </section>

      <section id="sobre-mi" data-section data-reveal class="reveal-up mx-auto flex min-h-screen w-full max-w-6xl flex-col justify-center px-5 py-16 md:px-8">
        <h2 class="mt-2 text-4xl font-bold tracking-tight text-white">Sobre mi</h2>
        <div class="mt-8 grid gap-3 md:grid-cols-3">
          <div class="flex flex-col gap-3">
            <article class="panel-card">
              <p class="panel-title">about-me</p>
              <p class="mt-4 text-sm leading-relaxed text-[#A1A1AA]">Ingeniera Informática en formación con un enfoque apasionado en el Desarrollo Fullstack y la Ciberseguridad. Mi valor diferencial radica en la intersección entre la robustez técnica y la visión estratégica de marketing.</p>
              <p class="mt-3 text-sm leading-relaxed text-[#A1A1AA]">Con experiencia en la creación de soluciones escalables en Python y JavaScript, y certificaciones internacionales por IBM y Fortinet, busco transformar desafíos complejos en productos digitales seguros, eficientes y centrados en el usuario.</p>
            </article>
            <article class="panel-card">
              <p class="panel-title">me-online</p>
              <div class="mt-4 space-y-2 text-sm">
                <a href="https://www.linkedin.com/in/massiel-perozo-5b30b4304/" target="_blank" rel="noopener noreferrer" class="block text-[#A1A1AA] hover:text-[#8B5CF6]">linkedin</a>
                <a href="https://github.com/massiperozo" target="_blank" rel="noopener noreferrer" class="block text-[#A1A1AA] hover:text-[#8B5CF6]">github</a>
                <a href="https://mail.google.com/mail/?view=cm&fs=1&to=massiperozob@gmail.com" class="block text-[#A1A1AA] hover:text-[#8B5CF6]">email</a>
              </div>
            </article>
          </div>
          <div class="flex flex-col gap-3">
            <article class="panel-card">
              <p class="panel-title">where-i-work</p>
              <p class="mt-4 text-sm text-[#A1A1AA]">Actualmente en Venezuela.</p>
              <p class="mt-2 text-sm text-[#A1A1AA]">Disponible para colaboraciones remotas en Latinoamerica y worldwide.</p>
              <p class="mt-3 text-sm leading-relaxed text-[#A1A1AA]">Ayudo a empresas y equipos tecnológicos a construir productos digitales que no solo son funcionales y estéticamente atractivos, sino también seguros y escalables desde el primer día. Como estudiante de Ingeniería Informática y mentora de código, aplico una mentalidad analítica para resolver problemas complejos, integrando mi experiencia en marketing digital para asegurar que cada solución técnica esté alineada con los objetivos del usuario y del negocio.</p>
            </article>
          </div>
          <div class="flex flex-col gap-3">
            <article class="panel-card">
              <p class="panel-title">collaborations</p>
              <p class="mt-4 text-sm text-[#A1A1AA]">Trabajo con agencias, estudios digitales e iniciativas educativas con impacto.</p>
            </article>
            <article class="panel-card">
              <p class="panel-title">instituciones</p>
              <div class="mt-4 flex items-center gap-3">
                <img src={technovationLogo.src} alt="Technovation Girls" class="h-8 w-auto" loading="lazy" />
                <img src={ucaLogo.src} alt="UCAB" class="h-8 w-auto" loading="lazy" />
              </div>
            </article>
            <article class="panel-card panel-card-purple relative overflow-hidden">
              <p class="panel-title">portrait</p>
              <div class="mt-5 grid place-items-center rounded-xl border border-black/20 bg-[#8B5CF6] p-5">
                <img src={massielProfile.src} alt="Retrato de Massiel Perozo" class="h-52 w-full max-w-full scale-[1.08] origin-center rounded-lg object-contain object-center" loading="lazy" />
              </div>
            </article>
          </div>
        </div>
      </section>

      <section id="experiencia" data-section data-reveal class="reveal-up mx-auto flex min-h-screen w-full max-w-6xl flex-col justify-center px-5 py-16 md:px-8">
        <h2 class="mt-2 text-4xl font-bold tracking-tight text-white">Experiencia</h2>
        <p class="mt-4 text-xs text-[#A1A1AA]">// pasantias y experiencia profesional</p>

        <div class="mt-8 space-y-4">
          {
            experiences.map((experience, index) => (
              <article class="rounded-2xl border border-white/12 bg-[#19191D]/85 p-5 transition hover:-translate-y-1 hover:border-[#8B5CF6]/60">
                <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
                  <div class="flex items-start gap-4">
                    <div class="grid h-14 w-14 shrink-0 place-items-center rounded-2xl border border-white/12 bg-white/[0.04] text-[#8B5CF6]">
                      <span class="text-sm font-bold">0{index + 1}</span>
                    </div>
                    <div>
                      <h3 class="text-2xl font-semibold leading-tight text-white">{experience.role}</h3>
                      <p class="mt-1 text-sm text-white/82">{experience.company}</p>
                      <p class="mt-1 text-sm text-white/50">{experience.period}</p>
                    </div>
                  </div>
                  <span class="rounded-full border border-[#8B5CF6]/40 bg-[#8B5CF6]/10 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-[#C4B5FD]">
                    Pasantía
                  </span>
                </div>
                <p class="mt-4 max-w-4xl text-sm leading-relaxed text-[#A1A1AA]">{experience.description}</p>
                {experience.tags.length > 0 && (
                  <div class="mt-4 flex flex-wrap gap-2">
                    {experience.tags.map((tag) => <span class="rounded-full border border-white/15 px-3 py-1 text-[11px] text-white/72">{tag}</span>)}
                  </div>
                )}
              </article>
            ))
          }
        </div>
      </section>

      <section id="proyectos" data-section data-reveal class="reveal-up mx-auto flex min-h-screen w-full max-w-6xl flex-col justify-center px-5 py-16 md:px-8">
        <h2 class="mt-2 text-4xl font-bold tracking-tight text-white">Proyectos</h2>
        <p class="mt-4 text-xs text-[#A1A1AA]">// proyectos mas impactantes</p>
        <div class="mt-8 grid gap-4 md:grid-cols-2">
          {
            projects.map((project, index) => (
              <article class="group rounded-2xl border border-white/12 bg-[#19191D]/80 p-5 transition hover:-translate-y-1 hover:border-[#8B5CF6]/60">
                <div class="flex items-center justify-between text-xs text-white/45">
                  <span>0{index + 1}</span>
                  <span>{project.year}</span>
                </div>
                <h3 class="mt-3 text-3xl font-semibold leading-tight text-white">{project.title}</h3>
                <p class="mt-3 text-sm leading-relaxed text-[#A1A1AA]">{project.description}</p>
                <div class="mt-4 flex flex-wrap gap-2">
                  {project.tags.map((tag) => <span class="rounded-full border border-[#8B5CF6]/45 px-2 py-1 text-[11px] text-[#C4B5FD]">{tag}</span>)}
                </div>
                <div class="mt-6 flex items-center justify-between">
                  <span class="text-sm text-white/58">ver más</span>
                  <a href={project.href} target="_blank" rel="noopener noreferrer" class="rounded-lg bg-[#8B5CF6] px-4 py-2 text-xs font-semibold text-white transition hover:bg-[#C4B5FD] hover:text-[#0F0F12]">Ver proyecto -&gt;</a>
                </div>
              </article>
            ))
          }
        </div>

        <a href="https://github.com/massiperozo" target="_blank" rel="noopener noreferrer" class="mt-8 inline-flex w-fit items-center gap-2 rounded-full border border-white/20 bg-white/[0.02] px-4 py-2 text-sm text-white/82 hover:border-[#8B5CF6]/50 hover:text-[#C4B5FD]">Ver todos los proyectos en GitHub -&gt;</a>
      </section>

      <section id="skills" data-section data-reveal class="reveal-up mx-auto flex min-h-screen w-full max-w-6xl flex-col justify-center px-5 py-16 md:px-8">
        <h2 class="mt-2 text-4xl font-bold tracking-tight text-white">Skills & Stack</h2>
        <p class="mt-4 text-xs text-[#A1A1AA]">// stack técnico para conectar</p>

        <div class="mt-6 max-w-xl rounded-lg border border-white/15 bg-[#19191D] p-4 font-mono text-xs text-[#C4B5FD]">
          <p>&gt; Iniciando perfil...</p>
          <p class="mt-2 text-white">Massiel Perozo</p>
          <p>Ingeniera Informatica | UCAB</p>
          <p class="mt-2">- Desarrollo Fullstack (JS/TS, Python)</p>
          <p>- Ciberseguridad (IBM, Fortinet)</p>
          <p>- Estrategia digital y producto</p>
          <div class="mt-3 flex items-center gap-2">
            <img src={ibmLogo.src} alt="IBM" class="h-5 w-auto" loading="lazy" />
            <img src={fortinetLogo.src} alt="Fortinet" class="h-5 w-auto" loading="lazy" />
          </div>
        </div>

        <div class="mt-8 grid gap-4 md:grid-cols-6">
          {
            skillCards.map((card) => (
              <article class={`panel-card ${card.emphasis ? 'md:col-span-3 ring-1 ring-[#8B5CF6]/40' : 'md:col-span-2'}`}>
                <h3 class="text-lg font-semibold text-white">{card.title}</h3>
                <p class="mt-1 text-xs uppercase tracking-[0.18em] text-[#C4B5FD]">{card.subtitle}</p>
                <p class="mt-3 text-sm leading-relaxed text-[#A1A1AA]">{card.description}</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {card.tags.map((tag) => <span class="rounded border border-white/15 px-1.5 py-0.5 text-[10px] text-white/70">{tag}</span>)}
                </div>
              </article>
            ))
          }
        </div>

        <div class="mt-8 flex items-center justify-between rounded-xl border border-white/12 bg-[#19191D] px-4 py-3 text-sm text-[#A1A1AA]">
          <span>Buscas una desarrolladora que entienda tanto el codigo como el producto?</span>
          <a href="#contacto" class="rounded bg-[#8B5CF6] px-3 py-1.5 text-xs font-semibold text-white hover:bg-[#C4B5FD] hover:text-[#0F0F12]">Hablemos -&gt;</a>
