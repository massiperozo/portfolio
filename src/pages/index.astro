  let currentLanguage: Language = 'es';
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const langButtons = document.querySelectorAll<HTMLButtonElement>('[data-lang-switch]');

  function applyTranslations(lang: Language) {
    const dictionary = translations[lang];

    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((element) => {
      const key = element.dataset.i18n;
      if (!key || !dictionary[key]) return;
      element.textContent = dictionary[key];
    });

    document.querySelectorAll<HTMLElement>('[data-i18n-aria]').forEach((element) => {
      const key = element.dataset.i18nAria;
      if (!key || !dictionary[key]) return;
      element.setAttribute('aria-label', dictionary[key]);
    });

    document.querySelectorAll<HTMLElement>('[data-i18n-title]').forEach((element) => {
      const key = element.dataset.i18nTitle;
      if (!key || !dictionary[key]) return;
      element.setAttribute('title', dictionary[key]);
    });

    document.documentElement.lang = lang;
  }

  function updateLanguageButtons(lang: Language) {
    langButtons.forEach((button) => {
      const isActive = button.dataset.langSwitch === lang;
      button.classList.toggle('bg-[#8B5CF6]', isActive);
      button.classList.toggle('text-white', isActive);
      button.classList.toggle('text-white/70', !isActive);
    });
  }

  function setLanguage(lang: Language) {
    currentLanguage = lang;
    applyTranslations(lang);
    updateLanguageButtons(lang);
    localStorage.setItem('portfolio-language', lang);
    updateVenezuelaTime();
  }

  function updateVenezuelaTime() {
    const el = document.getElementById('local-time-value');
    if (!el) return;
    const now = new Date();
    const options: Intl.DateTimeFormatOptions = {
      hour: '2-digit',
      minute: '2-digit',
      hour12: false,
      timeZone: 'America/Caracas',
    };
    const locale = currentLanguage === 'en' ? 'en-US' : 'es-VE';
    el.textContent = new Intl.DateTimeFormat(locale, options).format(now);
  }

  const savedLanguage = localStorage.getItem('portfolio-language');
  const preferredLanguage: Language = savedLanguage === 'en' || savedLanguage === 'es'
    ? savedLanguage
    : (navigator.language.toLowerCase().startsWith('en') ? 'en' : 'es');

  setLanguage(preferredLanguage);

  setInterval(updateVenezuelaTime, 60000);

  const translateButtons = document.querySelectorAll<HTMLButtonElement>('[data-translate-button]');
  langButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const lang = button.dataset.langSwitch;
      if (lang === 'es' || lang === 'en') {
        setLanguage(lang);
      }
    });
  });

  translateButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const nextLanguage: Language = currentLanguage === 'es' ? 'en' : 'es';
      setLanguage(nextLanguage);
    });
  });

  if (!reducedMotion) {
    const parallaxElements = document.querySelectorAll<HTMLElement>('[data-parallax]');
    const reveals = document.querySelectorAll<HTMLElement>('[data-reveal]');
    const navLinks = document.querySelectorAll<HTMLElement>('[data-nav-link]');
    const sections = document.querySelectorAll<HTMLElement>('[data-section]');
    const progressBar = document.getElementById('scroll-progress') as HTMLElement | null;

    let ticking = false;
    const updateParallax = () => {
      const scrollY = window.scrollY;
      const maxScroll = Math.max(document.body.scrollHeight - window.innerHeight, 1);

      parallaxElements.forEach((element) => {
        const speed = Number(element.getAttribute('data-parallax')) || 0;
        element.style.transform = `translate3d(0, ${scrollY * speed}px, 0)`;
      });

      if (progressBar) {
        const progress = Math.min(100, Math.max(8, (scrollY / maxScroll) * 100));
        progressBar.style.height = `${progress}%`;
      }

      ticking = false;
    };

    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(updateParallax);
        ticking = true;
      }
    });

    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -10% 0px' }
    );

    reveals.forEach((section) => revealObserver.observe(section));

    const activeObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          const sectionId = entry.target.id;
          navLinks.forEach((link) => {
            const isActive = link.getAttribute('href') === `#${sectionId}`;
            link.classList.toggle('text-[#8B5CF6]', isActive);
            link.classList.toggle('text-white/65', !isActive);
          });
        });
      },
      { threshold: 0.5 }
    );

    sections.forEach((section) => {
      if (section.id) activeObserver.observe(section);
    });

    updateParallax();
  } else {
    document.querySelectorAll<HTMLElement>('[data-reveal]').forEach((section) => section.classList.add('is-visible'));
  }
</script>
